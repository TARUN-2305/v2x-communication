# ECO-SYNC V2X — Production Environment Variables
# Copy to .env and fill in values

# ── LLM (Primary) ─────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here          # get free at console.groq.com

# ── LLM Fallback (Ollama — must be running locally) ───────────────────────────
OLLAMA_HOST=http://host.docker.internal:11434  # Docker reaches your local Ollama
OLLAMA_PRIMARY=gemma3:4b                       # ollama pull gemma3:4b  (maps to gemma4:e2b)
OLLAMA_FALLBACK=phi3:latest                    # ollama pull phi3:latest

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=ecosync2026

# ── Simulation ────────────────────────────────────────────────────────────────
NUM_BUSES=6           # buses on route simultaneously (2–8)
SIM_SPEED=1.0         # 1.0 = real-time, 5.0 = 5× speed

# ── MQTT (set automatically by docker-compose) ────────────────────────────────
# MQTT_HOST=mqtt
# MQTT_PORT=1883
